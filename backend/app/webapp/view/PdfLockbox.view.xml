<mvc:View
    controllerName="lockbox.controller.PdfLockbox"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
    xmlns:table="sap.ui.table"
    displayBlock="true"
    height="100%">
    
    <Page id="pdfLockboxPage" title="PDF Lockbox - AI-Powered Document Processing" showHeader="true">
        <customHeader>
            <Toolbar design="Solid">
                <Button icon="sap-icon://nav-back" press="onNavBack" tooltip="Back to Home" />
                <ToolbarSpacer />
                <Title text="PDF Lockbox (OCR)" level="H2" />
                <ToolbarSpacer />
            </Toolbar>
        </customHeader>
        
        <content>
            <VBox class="sapUiSmallMargin">
                
                <!-- Header Section with Upload -->
                <l:VerticalLayout class="sapUiLargeMarginBottom">
                    <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMarginBottom">
                        <VBox>
                            <Title text="Upload PDF Documents" level="H3" />
                            <Text text="AI-powered OCR extraction using Claude AI" />
                        </VBox>
                        <HBox>
                            <Button
                                text="Upload PDF"
                                icon="sap-icon://upload"
                                type="Emphasized"
                                press="onUploadPdf"
                                tooltip="Upload PDF file for AI OCR processing" />
                            <Button
                                icon="sap-icon://refresh"
                                press="onRefreshData"
                                tooltip="Refresh data"
                                class="sapUiTinyMarginBegin" />
                        </HBox>
                    </HBox>
                    
                    <!-- Info Panel -->
                    <MessageStrip
                        text="Upload PDF files containing invoices, payment remittances, or bank statements. AI will extract payment data automatically."
                        type="Information"
                        showIcon="true"
                        class="sapUiSmallMarginBottom" />
                </l:VerticalLayout>
                
                <!-- PDF Runs Table -->
                <Table
                    id="pdfRunsTable"
                    items="{app>/pdfRuns}"
                    growing="true"
                    growingThreshold="20"
                    sticky="ColumnHeaders,HeaderToolbar"
                    class="sapUiSmallMarginTop">
                    <headerToolbar>
                        <OverflowToolbar>
                            <Title text="PDF Processing Runs" level="H4" />
                            <ToolbarSpacer />
                            <Label text="Total: {app>/pdfRunsCount}" />
                        </OverflowToolbar>
                    </headerToolbar>
                    <columns>
                        <Column width="10%">
                            <Text text="Run ID" />
                        </Column>
                        <Column width="15%">
                            <Text text="File Name" />
                        </Column>
                        <Column width="10%">
                            <Text text="Status" />
                        </Column>
                        <Column width="15%">
                            <Text text="OCR Details" />
                        </Column>
                        <Column width="10%">
                            <Text text="Rows Extracted" />
                        </Column>
                        <Column width="15%">
                            <Text text="Uploaded At" />
                        </Column>
                        <Column width="15%">
                            <Text text="Actions" />
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{app>runId}" />
                                <Text text="{app>filename}" />
                                <ObjectStatus
                                    text="{app>overallStatus}"
                                    state="{= ${app>overallStatus} === 'posted' ? 'Success' : ${app>overallStatus} === 'failed' ? 'Error' : ${app>overallStatus} === 'simulated' ? 'Warning' : 'None' }" />
                                <VBox>
                                    <Text text="Provider: {app>stages/ocr/provider}" />
                                    <Text text="Model: {app>stages/ocr/model}" />
                                </VBox>
                                <Text text="{app>stages/extraction/rowCount}" />
                                <Text text="{app>uploadedAt}" />
                                <HBox>
                                    <Button
                                        icon="sap-icon://detail-view"
                                        type="Transparent"
                                        press="onViewDetails"
                                        tooltip="View Details" />
                                </HBox>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
                
            </VBox>
            
            <!-- PDF Upload Dialog -->
            <Dialog id="pdfUploadDialog" title="Upload PDF File" contentWidth="500px">
                <content>
                    <VBox class="sapUiSmallMargin">
                        <Label text="Select PDF File" class="sapUiSmallMarginBottom" />
                        <Text text="Upload PDF files containing payment information. Claude AI will extract the data automatically." class="sapUiSmallMarginBottom" />
                        
                        <core:HTML content='&lt;input type="file" id="pdfFileInput" accept=".pdf" style="width: 100%; padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px;" /&gt;' class="sapUiSmallMarginBottom" />
                        
                        <MessageStrip
                            text="Supported: Invoices, Payment Remittances, Bank Statements"
                            type="Information"
                            showIcon="true" />
                    </VBox>
                </content>
                <beginButton>
                    <Button text="Upload &amp; Process" press="onUploadPdfFile" type="Emphasized" icon="sap-icon://upload" />
                </beginButton>
                <endButton>
                    <Button text="Cancel" press="onClosePdfUploadDialog" />
                </endButton>
            </Dialog>
            
        </content>
    </Page>
</mvc:View>
