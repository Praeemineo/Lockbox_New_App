<mvc:View
    controllerName="lockbox.controller.ProcessingRules"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    displayBlock="true"
    height="100%">
    
    <!-- Simple inline content - no separate Page wrapper -->
    <VBox class="sapUiSmallMargin">
        <!-- Page Header -->
        <HBox alignItems="Center" class="sapUiSmallMarginBottom">
            <core:Icon src="sap-icon://decision" size="1.5rem" color="#0854a0" class="sapUiSmallMarginEnd" />
            <Title text="Manage Lockbox Processing Rules" level="H2" />
        </HBox>
        
        <!-- Filter Bar -->
        <Panel headerText="Filters" expandable="true" expanded="true" class="sapUiSmallMarginBottom">
            <VBox class="sapUiSmallMargin">
                <HBox alignItems="End" wrap="Wrap">
                    <!-- File Type Filter -->
                    <VBox class="sapUiSmallMarginEnd" width="150px">
                        <Label text="File Type" />
                        <Select id="filterFileType" selectedKey="{app>/processingRuleFilters/fileType}" width="100%">
                            <core:Item key="" text="All" />
                            <core:Item key="EXCEL" text="Excel" />
                            <core:Item key="CSV" text="CSV" />
                            <core:Item key="BAI2" text="BAI2" />
                            <core:Item key="PDF" text="PDF" />
                        </Select>
                    </VBox>
                    
                    <!-- Rule Type Filter -->
                    <VBox class="sapUiSmallMarginEnd" width="150px">
                        <Label text="Rule Type" />
                        <Select id="filterRuleType" selectedKey="{app>/processingRuleFilters/ruleType}" width="100%">
                            <core:Item key="" text="All" />
                            <core:Item key="SPLIT" text="Split" />
                            <core:Item key="EXPAND" text="Expand" />
                            <core:Item key="TRANSFORM" text="Transform" />
                            <core:Item key="VALIDATE" text="Validate" />
                            <core:Item key="PARSE" text="Parse" />
                            <core:Item key="EXTRACT" text="Extract" />
                        </Select>
                    </VBox>
                    
                    <!-- Active Filter -->
                    <VBox class="sapUiSmallMarginEnd" width="100px">
                        <Label text="Status" />
                        <Select id="filterActive" selectedKey="{app>/processingRuleFilters/active}" width="100%">
                            <core:Item key="" text="All" />
                            <core:Item key="true" text="Active" />
                            <core:Item key="false" text="Inactive" />
                        </Select>
                    </VBox>
                    
                    <!-- Rule ID Search -->
                    <VBox class="sapUiSmallMarginEnd" width="200px">
                        <Label text="Rule ID" />
                        <SearchField id="filterRuleId" placeholder="Search by Rule ID..." search="onProcessingRuleFilterGo" width="100%" />
                    </VBox>
                    
                    <!-- Filter Actions -->
                    <Button text="Go" type="Emphasized" press="onProcessingRuleFilterGo" class="sapUiSmallMarginEnd" />
                    <Button text="Clear" press="onClearProcessingRuleFilters" />
                </HBox>
            </VBox>
        </Panel>
        
        <!-- Processing Rules Table -->
        <Panel expandable="false">
            <headerToolbar>
                <OverflowToolbar>
                    <Title text="Processing Rules ({= ${app>/processingRules}.length})" />
                    <ToolbarSpacer />
                    <Button text="Create" icon="sap-icon://add" type="Emphasized" press="onCreateProcessingRule" />
                    <Button text="Copy" icon="sap-icon://copy" press="onCopyProcessingRule" enabled="{= !!${app>/selectedProcessingRule}}" />
                    <Button text="Delete" icon="sap-icon://delete" press="onDeleteProcessingRule" enabled="{= !!${app>/selectedProcessingRule}}" />
                    <Button icon="sap-icon://refresh" press="onRefreshProcessingRules" tooltip="Refresh" />
                </OverflowToolbar>
            </headerToolbar>
            <content>
                <Table
                    id="processingRulesTable"
                    items="{app>/processingRules}"
                    mode="SingleSelectMaster"
                    selectionChange="onProcessingRuleSelectionChange"
                    fixedLayout="false">
                    <columns>
                        <Column width="120px"><Text text="Rule ID" /></Column>
                        <Column width="120px"><Text text="File Type" /></Column>
                        <Column width="120px"><Text text="Rule Type" /></Column>
                        <Column><Text text="Description" /></Column>
                        <Column width="100px" hAlign="Center"><Text text="Status" /></Column>
                        <Column width="100px" hAlign="Center"><Text text="Actions" /></Column>
                    </columns>
                    <items>
                        <ColumnListItem type="Active" press="onEditProcessingRule">
                            <cells>
                                <ObjectIdentifier title="{app>ruleId}" />
                                <Text text="{app>fileType}" />
                                <ObjectStatus text="{app>ruleType}" state="Information" />
                                <Text text="{app>description}" wrapping="true" />
                                <Switch state="{app>active}" change="onProcessingRuleActiveToggle" customTextOn="Yes" customTextOff="No" />
                                <Button icon="sap-icon://edit" type="Transparent" press="onEditProcessingRule" tooltip="Edit Rule" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </content>
        </Panel>
    </VBox>
    
    <!-- Add/Edit Processing Rule Dialog -->
    <Dialog id="processingRuleDialog" title="{= ${app>/editingProcessingRule/ruleId} ? 'Edit Rule' : 'Create New Processing Rule'}" contentWidth="700px">
        <content>
            <VBox class="sapUiSmallMargin">
                <VBox class="sapUiSmallMarginBottom">
                    <Label text="Rule ID" required="true" />
                    <Input value="{app>/editingProcessingRule/ruleId}" placeholder="e.g., LB-RULE-008" width="100%" enabled="{= !${app>/editingProcessingRule/ruleId}}" />
                </VBox>
                <VBox class="sapUiSmallMarginBottom">
                    <Label text="File Type" required="true" />
                    <Select selectedKey="{app>/editingProcessingRule/fileType}" width="100%">
                        <core:Item key="Excel" text="Excel" />
                        <core:Item key="CSV" text="CSV" />
                        <core:Item key="BAI2" text="BAI2" />
                        <core:Item key="PDF" text="PDF" />
                        <core:Item key="All" text="All File Types" />
                    </Select>
                </VBox>
                <VBox class="sapUiSmallMarginBottom">
                    <Label text="Rule Type" required="true" />
                    <Select selectedKey="{app>/editingProcessingRule/ruleType}" width="100%">
                        <core:Item key="Split" text="Split" />
                        <core:Item key="Expand" text="Expand" />
                        <core:Item key="Transform" text="Transform" />
                        <core:Item key="Validate" text="Validate" />
                        <core:Item key="Parse" text="Parse" />
                        <core:Item key="Extract" text="Extract" />
                    </Select>
                </VBox>
                <VBox class="sapUiSmallMarginBottom">
                    <Label text="Description" required="true" />
                    <TextArea value="{app>/editingProcessingRule/description}" rows="3" width="100%" placeholder="Enter rule description..." />
                </VBox>
                <VBox>
                    <CheckBox text="Active" selected="{app>/editingProcessingRule/active}" />
                </VBox>
            </VBox>
        </content>
        <beginButton>
            <Button text="Save" type="Emphasized" press="onSaveProcessingRule" />
        </beginButton>
        <endButton>
            <Button text="Cancel" press="onCloseProcessingRuleDialog" />
        </endButton>
    </Dialog>
</mvc:View>
