<mvc:View
    controllerName="lockbox.controller.ProcessingRules"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    displayBlock="true"
    height="100%">
    
    <VBox class="sapUiSmallMargin">
        <!-- Page Header -->
        <HBox alignItems="Center" class="sapUiSmallMarginBottom">
            <core:Icon src="sap-icon://decision" size="1.5rem" color="#0854a0" class="sapUiSmallMarginEnd" />
            <Title text="Manage Lockbox Processing Rules" level="H2" />
        </HBox>
        
        <!-- Processing Rules Table -->
        <Panel expandable="false">
            <headerToolbar>
                <OverflowToolbar>
                    <Title text="Processing Rules ({= ${app>/processingRules} ? ${app>/processingRules}.length : 0})" />
                    <ToolbarSpacer />
                    <Button text="Create" icon="sap-icon://add" type="Emphasized" press="onCreateRule" />
                    <Button icon="sap-icon://refresh" press="onRefreshRules" tooltip="Refresh" />
                </OverflowToolbar>
            </headerToolbar>
            <content>
                <Table
                    id="rulesTable"
                    items="{app>/processingRules}"
                    mode="None"
                    fixedLayout="false">
                    <columns>
                        <Column width="15%"><Text text="Rule ID" /></Column>
                        <Column width="20%"><Text text="Rule Name" /></Column>
                        <Column width="30%"><Text text="Description" /></Column>
                        <Column width="15%"><Text text="Status" /></Column>
                        <Column width="15%"><Text text="Conditions" /></Column>
                        <Column width="5%" hAlign="Center"><Text text="" /></Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{app>rule_id}" />
                                <Text text="{app>rule_name}" />
                                <Text text="{app>description}" />
                                <ObjectStatus 
                                    text="{= ${app>is_active} ? 'Active' : 'Inactive'}" 
                                    state="{= ${app>is_active} ? 'Success' : 'None'}" />
                                <Text text="{= ${app>conditions} ? 'Configured' : 'Not Configured'}" />
                                <Button 
                                    icon="sap-icon://navigation-right-arrow" 
                                    type="Transparent"
                                    press="onShowRuleDetails"
                                    tooltip="View Rule Details" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </content>
        </Panel>
    </VBox>
    
    <!-- Rule Details Dialog with 3 Tabs -->
    <Dialog 
        id="ruleDetailsDialog" 
        contentWidth="90%"
        contentHeight="85%"
        resizable="true"
        draggable="true">
        <customHeader>
            <Bar class="dialogHeaderBar">
                <contentLeft>
                    <Title text="Rule: {app>/selectedRule/rule_id}" level="H3" class="dialogHeaderTitle" />
                </contentLeft>
                <contentRight>
                    <Button text="Save" icon="sap-icon://save" press="onSaveRule" class="dialogHeaderButton" />
                    <Button icon="sap-icon://decline" press="onCloseRuleDetails" tooltip="Close" class="dialogHeaderButton" />
                </contentRight>
            </Bar>
        </customHeader>
        <content>
            <IconTabBar id="ruleTabBar" class="sapUiResponsiveContentPadding" expandable="false">
                <items>
                    <!-- Tab 1: Processing Rule -->
                    <IconTabFilter text="Processing Rule" key="processingRule" icon="sap-icon://document">
                        <VBox class="sapUiSmallMargin">
                            <l:Grid defaultSpan="L6 M6 S12" hSpacing="1" vSpacing="1">
                                <l:content>
                                    <VBox>
                                        <Label text="Rule ID" class="sapUiTinyMarginBottom" />
                                        <Input value="{app>/selectedRule/rule_id}" enabled="false" />
                                    </VBox>
                                    <VBox>
                                        <Label text="Rule Name" required="true" class="sapUiTinyMarginBottom" />
                                        <Input value="{app>/selectedRule/rule_name}" placeholder="Enter rule name" />
                                    </VBox>
                                    <VBox>
                                        <Label text="Description" class="sapUiTinyMarginBottom" />
                                        <TextArea value="{app>/selectedRule/description}" rows="3" placeholder="Enter description" />
                                    </VBox>
                                    <VBox>
                                        <Label text="File Type" class="sapUiTinyMarginBottom" />
                                        <Select selectedKey="{app>/selectedRule/file_type}">
                                            <core:Item key="Excel" text="Excel" />
                                            <core:Item key="CSV" text="CSV" />
                                            <core:Item key="BAI2" text="BAI2" />
                                            <core:Item key="PDF" text="PDF" />
                                        </Select>
                                    </VBox>
                                    <VBox>
                                        <Label text="Rule Type" class="sapUiTinyMarginBottom" />
                                        <Select selectedKey="{app>/selectedRule/rule_type}">
                                            <core:Item key="Validation" text="Validation" />
                                            <core:Item key="Transformation" text="Transformation" />
                                            <core:Item key="Mapping" text="Mapping" />
                                            <core:Item key="Posting" text="Posting" />
                                        </Select>
                                    </VBox>
                                    <VBox>
                                        <Label text="Active" class="sapUiTinyMarginBottom" />
                                        <Switch state="{app>/selectedRule/is_active}" customTextOn="Active" customTextOff="Inactive" />
                                    </VBox>
                                </l:content>
                            </l:Grid>
                        </VBox>
                    </IconTabFilter>
                    
                    <!-- Tab 2: Conditions -->
                    <IconTabFilter text="Conditions" key="conditions" icon="sap-icon://filter" iconColor="Critical">
                        <VBox class="sapUiSmallMargin">
                            <Toolbar>
                                <Title text="Conditions" level="H4" />
                                <ToolbarSpacer />
                                <Button text="Add Condition" icon="sap-icon://add" type="Transparent" press="onAddCondition" />
                            </Toolbar>
                            <Table
                                id="conditionsTable"
                                items="{app>/selectedRule/conditions}"
                                mode="Delete"
                                delete="onDeleteCondition">
                                <columns>
                                    <Column width="25%"><Text text="Field" /></Column>
                                    <Column width="20%"><Text text="Operator" /></Column>
                                    <Column width="30%"><Text text="Value" /></Column>
                                    <Column width="25%"><Text text="Logic" /></Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Input value="{app>field}" placeholder="e.g., Amount" />
                                            <Select selectedKey="{app>operator}">
                                                <core:Item key="equals" text="Equals" />
                                                <core:Item key="notEquals" text="Not Equals" />
                                                <core:Item key="greaterThan" text="Greater Than" />
                                                <core:Item key="lessThan" text="Less Than" />
                                                <core:Item key="contains" text="Contains" />
                                            </Select>
                                            <Input value="{app>value}" placeholder="Enter value" />
                                            <Select selectedKey="{app>logic}">
                                                <core:Item key="AND" text="AND" />
                                                <core:Item key="OR" text="OR" />
                                            </Select>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </VBox>
                    </IconTabFilter>
                    
                    <!-- Tab 3: API Mappings -->
                    <IconTabFilter text="API Mappings" key="apiMappings" icon="sap-icon://chain-link" iconColor="Positive">
                        <VBox class="sapUiSmallMargin">
                            <Toolbar>
                                <Title text="API Field Mappings" level="H4" />
                                <ToolbarSpacer />
                                <Button text="Add Mapping" icon="sap-icon://add" type="Transparent" press="onAddMapping" />
                            </Toolbar>
                            <Table
                                id="mappingsTable"
                                items="{app>/selectedRule/api_mappings}"
                                mode="Delete"
                                delete="onDeleteMapping">
                                <columns>
                                    <Column width="30%"><Text text="Source Field" /></Column>
                                    <Column width="30%"><Text text="Target Field (SAP)" /></Column>
                                    <Column width="20%"><Text text="Transformation" /></Column>
                                    <Column width="20%"><Text text="Required" /></Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Input value="{app>source_field}" placeholder="Excel Column / CSV Field" />
                                            <Input value="{app>target_field}" placeholder="SAP Field Name" />
                                            <Select selectedKey="{app>transformation}">
                                                <core:Item key="none" text="None" />
                                                <core:Item key="uppercase" text="Uppercase" />
                                                <core:Item key="lowercase" text="Lowercase" />
                                                <core:Item key="trim" text="Trim" />
                                                <core:Item key="dateFormat" text="Date Format" />
                                            </Select>
                                            <Switch state="{app>required}" />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </VBox>
                    </IconTabFilter>
                </items>
            </IconTabBar>
        </content>
    </Dialog>
</mvc:View>
    
    <!-- Add/Edit Processing Rule Dialog with 3 Tabs -->
    <Dialog 
        id="processingRuleDialog" 
        title="{= ${app>/editingProcessingRule/ruleId} ? ('Rule: ' + ${app>/editingProcessingRule/ruleId}) : 'Create New Processing Rule'}" 
        contentWidth="900px"
        contentHeight="600px">
        <content>
            <IconTabBar id="ruleTabBar" class="sapUiResponsiveContentPadding">
                <!-- Tab 1: Processing Rule -->
                <items>
                    <IconTabFilter text="Processing Rule" key="processingRule">
                        <l:Grid defaultSpan="L6 M6 S12" width="auto" class="sapUiSmallMargin">
                            <l:content>
                                <VBox class="sapUiSmallMarginBottom">
                                    <Label text="Description" required="true" />
                                    <Input value="{app>/editingProcessingRule/description}" placeholder="Process New Rule" />
                                </VBox>
                                <VBox class="sapUiSmallMarginBottom">
                                    <Label text="Journal Entry Type" />
                                    <Input value="{app>/editingProcessingRule/journalEntryType}" placeholder="ZV (Payment Clearing)" />
                                </VBox>
                                <VBox class="sapUiSmallMarginBottom">
                                    <Label text="Rule For" required="true" />
                                    <RadioButtonGroup selectedIndex="{app>/editingProcessingRule/ruleForIndex}">
                                        <RadioButton text="Incoming Payment" />
                                        <RadioButton text="Outgoing Payment" />
                                    </RadioButtonGroup>
                                </VBox>
                                <VBox class="sapUiSmallMarginBottom">
                                    <Label text="Action Type" />
                                    <Select selectedKey="{app>/editingProcessingRule/actionType}">
                                        <core:Item key="G/L Posting" text="G/L Posting" />
                                        <core:Item key="Customer Posting" text="Customer Posting" />
                                        <core:Item key="Vendor Posting" text="Vendor Posting" />
                                    </Select>
                                </VBox>
                                <HBox class="sapUiSmallMarginBottom">
                                    <VBox class="sapUiSmallMarginEnd">
                                        <Label text="Share Rule" />
                                        <Switch state="{app>/editingProcessingRule/shareRule}" customTextOn="YES" customTextOff="NO" />
                                    </VBox>
                                    <VBox>
                                        <Label text="Ignore Processor" />
                                        <Switch state="{app>/editingProcessingRule/ignoreProcessor}" customTextOn="YES" customTextOff="NO" />
                                    </VBox>
                                </HBox>
                            </l:content>
                        </l:Grid>
                    </IconTabFilter>
                    
                    <!-- Tab 2: Condition -->
                    <IconTabFilter text="Condition" key="condition">
                        <VBox class="sapUiSmallMargin">
                            <HBox justifyContent="SpaceBetween" class="sapUiSmallMarginBottom">
                                <Title text="Condition (1)" level="H5" />
                                <HBox>
                                    <Select selectedKey="Standard" class="sapUiSmallMarginEnd">
                                        <core:Item key="Standard" text="Standard" />
                                        <core:Item key="Expert" text="Expert" />
                                    </Select>
                                    <SearchField placeholder="Search" width="200px" />
                                </HBox>
                            </HBox>
                            <Table
                                id="conditionsTable"
                                items="{app>/editingProcessingRule/conditions}"
                                mode="Delete"
                                delete="onDeleteCondition">
                                <headerToolbar>
                                    <OverflowToolbar>
                                        <ToolbarSpacer />
                                        <Button text="Add Condition" icon="sap-icon://add" press="onAddCondition" />
                                    </OverflowToolbar>
                                </headerToolbar>
                                <columns>
                                    <Column width="25%"><Text text="Attribute" /></Column>
                                    <Column width="20%"><Text text="Option" /></Column>
                                    <Column width="25%"><Text text="From" /></Column>
                                    <Column width="25%"><Text text="To" /></Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Input value="{app>attribute}" placeholder="Lockbox Destination" />
                                            <Select selectedKey="{app>option}">
                                                <core:Item key="equals" text="equals" />
                                                <core:Item key="contains" text="contains" />
                                                <core:Item key="startsWith" text="starts with" />
                                                <core:Item key="endsWith" text="ends with" />
                                            </Select>
                                            <Input value="{app>from}" placeholder="LOCKBOXDES" />
                                            <Input value="{app>to}" placeholder="" />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </VBox>
                    </IconTabFilter>
                    
                    <!-- Tab 3: Post to G/L Account -->
                    <IconTabFilter text="Post to G/L Account" key="glAccount">
                        <VBox class="sapUiSmallMargin">
                            <HBox justifyContent="SpaceBetween" class="sapUiSmallMarginBottom">
                                <Title text="Post to G/L Account (1)" level="H5" />
                                <Select selectedKey="Standard">
                                    <core:Item key="Standard" text="Standard" />
                                    <core:Item key="Expert" text="Expert" />
                                </Select>
                            </HBox>
                            <Table
                                id="glAccountsTable"
                                items="{app>/editingProcessingRule/glAccounts}"
                                mode="Delete"
                                delete="onDeleteGLAccount">
                                <headerToolbar>
                                    <OverflowToolbar>
                                        <ToolbarSpacer />
                                        <Button text="Add G/L Account" icon="sap-icon://add" press="onAddGLAccount" />
                                    </OverflowToolbar>
                                </headerToolbar>
                                <columns>
                                    <Column><Text text="Account" /></Column>
                                    <Column><Text text="Profit Center" /></Column>
                                    <Column><Text text="Cost Center" /></Column>
                                    <Column><Text text="Tax Code" /></Column>
                                    <Column><Text text="Segment" /></Column>
                                    <Column><Text text="Functional Area" /></Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Input value="{app>account}" placeholder="21180000" />
                                            <Input value="{app>profitCenter}" placeholder="YB911" />
                                            <Input value="{app>costCenter}" placeholder="" />
                                            <Input value="{app>taxCode}" placeholder="" />
                                            <Input value="{app>segment}" placeholder="" />
                                            <Input value="{app>functionalArea}" placeholder="" />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </VBox>
                    </IconTabFilter>
                </items>
            </IconTabBar>
        </content>
        <beginButton>
            <Button text="Save" type="Emphasized" press="onSaveProcessingRule" />
        </beginButton>
        <endButton>
            <Button text="Cancel" press="onCloseProcessingRuleDialog" />
        </endButton>
    </Dialog>
</mvc:View>