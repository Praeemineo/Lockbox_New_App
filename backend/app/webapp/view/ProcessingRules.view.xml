<mvc:View
    controllerName="lockbox.controller.ProcessingRules"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    displayBlock="true"
    height="100%">
    
    <VBox class="sapUiSmallMargin">
        <!-- Page Header -->
        <HBox alignItems="Center" class="sapUiSmallMarginBottom">
            <core:Icon src="sap-icon://decision" size="1.5rem" color="#0854a0" class="sapUiSmallMarginEnd" />
            <Title text="Manage Lockbox Processing Rules" level="H2" />
        </HBox>
        
        <!-- Processing Rules Table -->
        <Panel expandable="false">
            <headerToolbar>
                <OverflowToolbar>
                    <Title text="Processing Rules ({= ${app>/processingRules}.length})" />
                    <ToolbarSpacer />
                    <Button text="Create" icon="sap-icon://add" type="Emphasized" press="onCreateProcessingRule" />
                    <Button text="Edit" icon="sap-icon://edit" press="onEditProcessingRule" enabled="{= !!${app>/selectedProcessingRule}}" />
                    <Button text="Delete" icon="sap-icon://delete" press="onDeleteProcessingRule" enabled="{= !!${app>/selectedProcessingRule}}" />
                    <Button icon="sap-icon://refresh" press="onRefreshProcessingRules" tooltip="Refresh" />
                </OverflowToolbar>
            </headerToolbar>
            <content>
                <Table
                    id="processingRulesTable"
                    items="{app>/processingRules}"
                    mode="SingleSelectMaster"
                    selectionChange="onProcessingRuleSelectionChange"
                    fixedLayout="false">
                    <columns>
                        <Column width="120px"><Text text="Rule_ID" /></Column>
                        <Column width="150px"><Text text="File_Type" /></Column>
                        <Column width="200px"><Text text="Rule_Type" /></Column>
                        <Column><Text text="Rule_Description" /></Column>
                        <Column width="120px" hAlign="Center"><Text text="Active/Inactive" /></Column>
                    </columns>
                    <items>
                        <ColumnListItem type="Active" press="onRowPress">
                            <cells>
                                <ObjectIdentifier title="{app>ruleId}" />
                                <Text text="{app>fileType}" />
                                <ObjectStatus text="{app>ruleType}" state="Information" />
                                <Text text="{app>ruleDescription}" wrapping="true" />
                                <Switch state="{app>active}" change="onProcessingRuleActiveToggle" customTextOn="Active" customTextOff="Inactive" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </content>
        </Panel>
    </VBox>
    
    <!-- Add/Edit Processing Rule Dialog with 3 Tabs -->
    <Dialog 
        id="processingRuleDialog" 
        title="{= ${app>/editingProcessingRule/ruleId} ? ('Rule: ' + ${app>/editingProcessingRule/ruleId}) : 'Create New Processing Rule'}" 
        contentWidth="900px"
        contentHeight="600px">
        <content>
            <IconTabBar id="ruleTabBar" class="sapUiResponsiveContentPadding">
                <!-- Tab 1: Processing Rule -->
                <items>
                    <IconTabFilter text="Processing Rule" key="processingRule">
                        <l:Grid defaultSpan="L6 M6 S12" width="auto" class="sapUiSmallMargin">
                            <l:content>
                                <VBox class="sapUiSmallMarginBottom">
                                    <Label text="Description" required="true" />
                                    <Input value="{app>/editingProcessingRule/description}" placeholder="Process New Rule" />
                                </VBox>
                                <VBox class="sapUiSmallMarginBottom">
                                    <Label text="Journal Entry Type" />
                                    <Input value="{app>/editingProcessingRule/journalEntryType}" placeholder="ZV (Payment Clearing)" />
                                </VBox>
                                <VBox class="sapUiSmallMarginBottom">
                                    <Label text="Rule For" required="true" />
                                    <RadioButtonGroup selectedIndex="{app>/editingProcessingRule/ruleForIndex}">
                                        <RadioButton text="Incoming Payment" />
                                        <RadioButton text="Outgoing Payment" />
                                    </RadioButtonGroup>
                                </VBox>
                                <VBox class="sapUiSmallMarginBottom">
                                    <Label text="Action Type" />
                                    <Select selectedKey="{app>/editingProcessingRule/actionType}">
                                        <core:Item key="G/L Posting" text="G/L Posting" />
                                        <core:Item key="Customer Posting" text="Customer Posting" />
                                        <core:Item key="Vendor Posting" text="Vendor Posting" />
                                    </Select>
                                </VBox>
                                <HBox class="sapUiSmallMarginBottom">
                                    <VBox class="sapUiSmallMarginEnd">
                                        <Label text="Share Rule" />
                                        <Switch state="{app>/editingProcessingRule/shareRule}" customTextOn="YES" customTextOff="NO" />
                                    </VBox>
                                    <VBox>
                                        <Label text="Ignore Processor" />
                                        <Switch state="{app>/editingProcessingRule/ignoreProcessor}" customTextOn="YES" customTextOff="NO" />
                                    </VBox>
                                </HBox>
                            </l:content>
                        </l:Grid>
                    </IconTabFilter>
                    
                    <!-- Tab 2: Condition -->
                    <IconTabFilter text="Condition" key="condition">
                        <VBox class="sapUiSmallMargin">
                            <HBox justifyContent="SpaceBetween" class="sapUiSmallMarginBottom">
                                <Title text="Condition (1)" level="H5" />
                                <HBox>
                                    <Select selectedKey="Standard" class="sapUiSmallMarginEnd">
                                        <core:Item key="Standard" text="Standard" />
                                        <core:Item key="Expert" text="Expert" />
                                    </Select>
                                    <SearchField placeholder="Search" width="200px" />
                                </HBox>
                            </HBox>
                            <Table
                                id="conditionsTable"
                                items="{app>/editingProcessingRule/conditions}"
                                mode="Delete"
                                delete="onDeleteCondition">
                                <headerToolbar>
                                    <OverflowToolbar>
                                        <ToolbarSpacer />
                                        <Button text="Add Condition" icon="sap-icon://add" press="onAddCondition" />
                                    </OverflowToolbar>
                                </headerToolbar>
                                <columns>
                                    <Column width="25%"><Text text="Attribute" /></Column>
                                    <Column width="20%"><Text text="Option" /></Column>
                                    <Column width="25%"><Text text="From" /></Column>
                                    <Column width="25%"><Text text="To" /></Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Input value="{app>attribute}" placeholder="Lockbox Destination" />
                                            <Select selectedKey="{app>option}">
                                                <core:Item key="equals" text="equals" />
                                                <core:Item key="contains" text="contains" />
                                                <core:Item key="startsWith" text="starts with" />
                                                <core:Item key="endsWith" text="ends with" />
                                            </Select>
                                            <Input value="{app>from}" placeholder="LOCKBOXDES" />
                                            <Input value="{app>to}" placeholder="" />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </VBox>
                    </IconTabFilter>
                    
                    <!-- Tab 3: Post to G/L Account -->
                    <IconTabFilter text="Post to G/L Account" key="glAccount">
                        <VBox class="sapUiSmallMargin">
                            <HBox justifyContent="SpaceBetween" class="sapUiSmallMarginBottom">
                                <Title text="Post to G/L Account (1)" level="H5" />
                                <Select selectedKey="Standard">
                                    <core:Item key="Standard" text="Standard" />
                                    <core:Item key="Expert" text="Expert" />
                                </Select>
                            </HBox>
                            <Table
                                id="glAccountsTable"
                                items="{app>/editingProcessingRule/glAccounts}"
                                mode="Delete"
                                delete="onDeleteGLAccount">
                                <headerToolbar>
                                    <OverflowToolbar>
                                        <ToolbarSpacer />
                                        <Button text="Add G/L Account" icon="sap-icon://add" press="onAddGLAccount" />
                                    </OverflowToolbar>
                                </headerToolbar>
                                <columns>
                                    <Column><Text text="Account" /></Column>
                                    <Column><Text text="Profit Center" /></Column>
                                    <Column><Text text="Cost Center" /></Column>
                                    <Column><Text text="Tax Code" /></Column>
                                    <Column><Text text="Segment" /></Column>
                                    <Column><Text text="Functional Area" /></Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Input value="{app>account}" placeholder="21180000" />
                                            <Input value="{app>profitCenter}" placeholder="YB911" />
                                            <Input value="{app>costCenter}" placeholder="" />
                                            <Input value="{app>taxCode}" placeholder="" />
                                            <Input value="{app>segment}" placeholder="" />
                                            <Input value="{app>functionalArea}" placeholder="" />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </VBox>
                    </IconTabFilter>
                </items>
            </IconTabBar>
        </content>
        <beginButton>
            <Button text="Save" type="Emphasized" press="onSaveProcessingRule" />
        </beginButton>
        <endButton>
            <Button text="Cancel" press="onCloseProcessingRuleDialog" />
        </endButton>
    </Dialog>
</mvc:View>