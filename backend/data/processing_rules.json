        "destination": "S4HANA_SYSTEM_DESTINATION",
        "inputField": "Customer",
        "sourceInput": "CustomerID",
        "outputField": "TermsOfPayment",
        "lockboxApiField": "PaymentTerm"
      }
    ],
    "createdAt": "2026-02-16T12:00:00Z",
