<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    
    <Dialog
        id="addColumnDialog"
        title="Add Custom Column"
        contentWidth="500px"
        contentHeight="auto">
        
        <content>
            <VBox class="sapUiSmallMargin">
                <Label text="Column Name" required="true" />
                <Input 
                    id="columnNameInput"
                    placeholder="e.g., Priority, Department, Owner"
                    value="{addColumnDialog>/columnName}" />
                
                <Label text="Column Type" required="true" class="sapUiSmallMarginTop" />
                <Select 
                    id="columnTypeSelect"
                    selectedKey="{addColumnDialog>/columnType}">
                    <core:Item key="text" text="Text" />
                    <core:Item key="number" text="Number" />
                    <core:Item key="date" text="Date" />
                    <core:Item key="select" text="Dropdown (Select)" />
                    <core:Item key="boolean" text="Yes/No (Boolean)" />
                </Select>
                
                <VBox visible="{= ${addColumnDialog>/columnType} === 'select'}" class="sapUiSmallMarginTop">
                    <Label text="Dropdown Options (comma-separated)" />
                    <Input 
                        placeholder="e.g., High, Medium, Low"
                        value="{addColumnDialog>/selectOptions}" />
                </VBox>
                
                <Label text="Default Value (Optional)" class="sapUiSmallMarginTop" />
                <Input 
                    placeholder="Default value for this column"
                    value="{addColumnDialog>/defaultValue}" />
            </VBox>
        </content>
        
        <beginButton>
            <Button text="Add Column" type="Emphasized" press="onConfirmAddColumn" />
        </beginButton>
        <endButton>
            <Button text="Cancel" press="onCancelAddColumn" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
