<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    xmlns:form="sap.ui.layout.form">
    
    <Dialog
        id="transactionDialog"
        title="Lockbox Processing"
        contentWidth="95%"
        contentHeight="85%"
        resizable="true"
        draggable="true">
        
        <content>
            <VBox class="sapUiSmallMargin">
                
                <!-- Header Information -->
                <layout:Grid
                    defaultSpan="XL4 L4 M6 S12"
                    class="sapUiSmallMarginBottom">
                    
                    <!-- First Row -->
                    <VBox class="sapUiSmallMarginBottom">
                        <Label text="Lockbox ID:" design="Bold"/>
                        <Text text="{transactionDialog>/lockboxId}"/>
                    </VBox>
                    
                    <VBox class="sapUiSmallMarginBottom">
                        <Label text="Processing Status:" design="Bold"/>
                        <ObjectStatus
                            text="{transactionDialog>/processingStatus}"
                            state="{= ${transactionDialog>/processingStatus} === 'Completed' ? 'Success' : 'None' }"/>
                    </VBox>
                    
                    <VBox></VBox>
                    
                    <!-- Second Row -->
                    <VBox class="sapUiSmallMarginBottom">
                        <Label text="Company Code:" design="Bold"/>
                        <Text text="{transactionDialog>/companyCode}"/>
                    </VBox>
                    
                    <VBox class="sapUiSmallMarginBottom">
                        <Label text="Company Code:" design="Bold"/>
                        <Text text="{transactionDialog>/companyCodeAlt}"/>
                    </VBox>
                    
                    <VBox></VBox>
                    
                    <!-- Third Row -->
                    <VBox class="sapUiSmallMarginBottom">
                        <Label text="Sending Bank:" design="Bold"/>
                        <Text text="{transactionDialog>/sendingBank}"/>
                    </VBox>
                    
                    <VBox class="sapUiSmallMarginBottom">
                        <Label text="Header Status:" design="Bold"/>
                        <ObjectStatus
                            text="{transactionDialog>/headerStatus}"
                            state="{= ${transactionDialog>/headerStatus} === 'Processed' ? 'Success' : 'None' }"/>
                    </VBox>
                    
                    <VBox></VBox>
                </layout:Grid>
                
                <OverflowToolbar class="sapUiTinyMarginTop">
                    <Title text="Lockbox Data" level="H4"/>
                    <ToolbarSpacer/>
                </OverflowToolbar>
                
                <!-- Tabs for Lockbox Data and Item Data -->
                <IconTabBar
                    id="transactionTabs"
                    select=".onTransactionTabSelect"
                    expandable="false"
                    class="sapUiResponsiveContentPadding">
                    
                    <!-- Item Data Tab -->
                    <items>
                        <IconTabFilter
                            text="Item Data"
                            key="itemData"
                            icon="sap-icon://list">
                            <Table
                                id="itemDataTable"
                                items="{transactionDialog>/itemData}"
                                growing="true"
                                growingThreshold="20"
                                mode="None"
                                class="sapUiSmallMarginTop">
                                <columns>
                                    <Column width="4rem">
                                        <Text text="Item"/>
                                    </Column>
                                    <Column width="8rem">
                                        <Text text="Bank Statement Item"/>
                                    </Column>
                                    <Column width="10rem">
                                        <Text text="Document Number"/>
                                    </Column>
                                    <Column width="10rem">
                                        <Text text="Payment Advice"/>
                                    </Column>
                                    <Column width="10rem">
                                        <Text text="Subledger Document"/>
                                    </Column>
                                    <Column width="10rem">
                                        <Text text="Subledger On-account"/>
                                    </Column>
                                    <Column width="8rem" hAlign="End">
                                        <Text text="Amount"/>
                                    </Column>
                                    <Column width="8rem">
                                        <Text text="Document Status"/>
                                    </Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Text text="{transactionDialog>item}"/>
                                            <Text text="{transactionDialog>bankStatementItem}"/>
                                            <Text text="{transactionDialog>documentNumber}"/>
                                            <Text text="{transactionDialog>paymentAdvice}"/>
                                            <Text text="{transactionDialog>subledgerDocument}"/>
                                            <Text text="{transactionDialog>subledgerOnAccount}"/>
                                            <Text text="{transactionDialog>amount}"/>
                                            <ObjectStatus
                                                text="{transactionDialog>documentStatus}"
                                                state="{= ${transactionDialog>documentStatus} === 'Cleared' ? 'Success' : 'None' }"/>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </IconTabFilter>
                    </items>
                </IconTabBar>
                
            </VBox>
        </content>
        
        <beginButton>
            <Button
                text="Refresh Data"
                icon="sap-icon://refresh"
                press=".onRefreshTransactionData"/>
        </beginButton>
        
        <endButton>
            <Button
                text="Close"
                press=".onCloseTransactionDialog"/>
        </endButton>
    </Dialog>
</core:FragmentDefinition>
