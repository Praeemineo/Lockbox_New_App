<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form">
    
    <Dialog
        id="patternDetailDialog"
        title="{patternDialog>/pattern/patternName}"
        contentWidth="95%"
        contentHeight="90%"
        resizable="true"
        draggable="true"
        stretch="true">
        
        <content>
            <IconTabBar
                id="patternDetailTabBar"
                select="onPatternTabSelect"
                class="sapUiResponsiveContentPadding">
                <items>
                    <!-- Tab 1: Processing Pattern -->
                    <IconTabFilter key="processingPattern" text="Processing Pattern" icon="sap-icon://document">
                        <VBox class="sapUiSmallMargin">
                            <f:SimpleForm
                                editable="true"
                                layout="ResponsiveGridLayout"
                                labelSpanXL="3"
                                labelSpanL="3"
                                labelSpanM="3"
                                labelSpanS="12"
                                adjustLabelSpan="false"
                                emptySpanXL="0"
                                emptySpanL="0"
                                emptySpanM="0"
                                emptySpanS="0"
                                columnsXL="2"
                                columnsL="2"
                                columnsM="1"
                                singleContainerFullSize="false">
                                <f:content>
                                    <Label text="Pattern ID" required="true" />
                                    <Input value="{patternDialog>/pattern/patternId}" enabled="{= !${patternDialog>/editMode}}" />
                                    
                                    <Label text="Pattern Name" required="true" />
                                    <Input value="{patternDialog>/pattern/patternName}" />
                                    
                                    <Label text="Description" />
                                    <TextArea value="{patternDialog>/pattern/description}" rows="3" />
                                    
                                    <Label text="File Type" required="true" />
                                    <Select selectedKey="{patternDialog>/pattern/fileType}">
                                        <core:Item key="EXCEL" text="Excel" />
                                        <core:Item key="CSV" text="CSV" />
                                        <core:Item key="PDF" text="PDF" />
                                        <core:Item key="XML" text="XML" />
                                    </Select>
                                    
                                    <Label text="Pattern Type" required="true" />
                                    <Input value="{patternDialog>/pattern/patternType}" placeholder="e.g., Single Check Multi Invoice" />
                                    
                                    <Label text="Category" />
                                    <Input value="{patternDialog>/pattern/category}" placeholder="e.g., CHECK, INVOICE, DATE" />
                                    
                                    <Label text="Delimiter" />
                                    <Input value="{patternDialog>/pattern/delimiter}" placeholder="e.g., comma (,) or hyphen (-)" />
                                    
                                    <Label text="Active" />
                                    <Switch state="{patternDialog>/pattern/active}" customTextOn="Yes" customTextOff="No" />
                                    
                                    <Label text="Priority" />
                                    <Input value="{patternDialog>/pattern/priority}" type="Number" />
                                </f:content>
                            </f:SimpleForm>
                        </VBox>
                    </IconTabFilter>
                    
                    <!-- Tab 2: Conditions -->
                    <IconTabFilter key="conditions" text="Conditions" count="{= ${patternDialog>/pattern/conditions} ? ${patternDialog>/pattern/conditions}.length : 0}" icon="sap-icon://filter">
                        <VBox class="sapUiSmallMargin">
                            <Toolbar>
                                <Title text="Pattern Conditions" level="H5" />
                                <ToolbarSpacer />
                                <Button text="Add Condition" icon="sap-icon://add" press="onAddPatternConditionRow" type="Emphasized" />
                            </Toolbar>
                            
                            <Table
                                id="patternConditionsDialogTable"
                                items="{patternDialog>/pattern/conditions}"
                                class="sapUiSizeCompact">
                                <columns>
                                    <Column width="45%">
                                        <Text text="Document/Date format" />
                                    </Column>
                                    <Column width="50%">
                                        <Text text="Condition" />
                                    </Column>
                                    <Column width="5%" hAlign="Center">
                                        <Text text="" />
                                    </Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Input value="{patternDialog>detectionCondition}" placeholder="e.g., Check, Check Amount, Invoice number" />
                                            <Input value="{patternDialog>condition}" placeholder="e.g., One check, Amount per Check" />
                                            <Button icon="sap-icon://delete" type="Reject" press="onDeletePatternConditionRow" tooltip="Delete" />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </VBox>
                    </IconTabFilter>
                    
                    <!-- Tab 3: Actions & Field Mapping -->
                    <IconTabFilter key="actionMapping" text="Actions &amp; Field Mapping" count="{= ${patternDialog>/pattern/actions} ? ${patternDialog>/pattern/actions}.length : 0}" icon="sap-icon://source-code">
                        <VBox class="sapUiSmallMargin">
                            <Toolbar>
                                <Title text="Action &amp; Field Mappings" level="H5" />
                                <ToolbarSpacer />
                                <Button text="Add Mapping" icon="sap-icon://add" press="onAddPatternActionRow" type="Emphasized" />
                            </Toolbar>
                            
                            <Table
                                id="patternActionsDialogTable"
                                items="{patternDialog>/pattern/actions}"
                                class="sapUiSizeCompact">
                                <columns>
                                    <Column width="30%">
                                        <Text text="Action Type" />
                                    </Column>
                                    <Column width="35%">
                                        <Text text="Related API/Field reference" />
                                    </Column>
                                    <Column width="30%">
                                        <Text text="Split Logic" />
                                    </Column>
                                    <Column width="5%" hAlign="Center">
                                        <Text text="" />
                                    </Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Input value="{patternDialog>actionType}" placeholder="e.g., Split_Invoice/Document_Number" />
                                            <Input value="{patternDialog>relatedApiField}" placeholder="e.g., Line1-90000393, Line2-90000394" />
                                            <Input value="{patternDialog>splitLogic}" placeholder="e.g., Comma delimiter, pad to 10 digits" />
                                            <Button icon="sap-icon://delete" type="Reject" press="onDeletePatternActionRow" tooltip="Delete" />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </VBox>
                    </IconTabFilter>
                </items>
            </IconTabBar>
        </content>
        
        <beginButton>
            <Button text="Save" type="Emphasized" press="onSavePatternDialog" />
        </beginButton>
        <endButton>
            <Button text="Cancel" press="onClosePatternDialog" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
