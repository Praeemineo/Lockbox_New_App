<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form">
    
    <Dialog
        id="processingRuleDialog"
        title="Processing Rule: {processingRuleDialog>/rule/ruleName}"
        contentWidth="90%"
        contentHeight="85%"
        resizable="true"
        draggable="true">
        
        <content>
            <IconTabBar
                id="processingRuleTabBar"
                select="onProcessingRuleTabSelect"
                class="sapUiResponsiveContentPadding">
                <items>
                    <IconTabFilter key="processingRule" text="Processing Rule" icon="sap-icon://business-objects-experience">
                        <VBox class="sapUiSmallMargin">
                            <f:SimpleForm
                                editable="true"
                                layout="ResponsiveGridLayout"
                                labelSpanXL="3"
                                labelSpanL="3"
                                labelSpanM="3"
                                labelSpanS="12"
                                adjustLabelSpan="false"
                                emptySpanXL="0"
                                emptySpanL="0"
                                emptySpanM="0"
                                emptySpanS="0"
                                columnsXL="2"
                                columnsL="2"
                                columnsM="1"
                                singleContainerFullSize="false">
                                <f:content>
                                    <Label text="Rule ID" />
                                    <VBox>
                                        <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                                            <Text text="{processingRuleDialog>/rule/ruleId}" class="sapUiTinyMarginEnd" />
                                            <core:Icon src="sap-icon://locked" color="#BB0000" size="1rem" class="sapUiTinyMarginEnd" />
                                            <Text text="(Auto-generated)" class="sapUiSmallMarginEnd" />
                                        </HBox>
                                        <MessageStrip 
                                            text="Rule ID will be automatically assigned when you save (e.g., RULE-001, RULE-002, etc.)" 
                                            type="Information" 
                                            showIcon="true"
                                            class="sapUiTinyMarginTop" />
                                    </VBox>
                                    
                                    <Label text="Rule Name" required="true" />
                                    <Input value="{processingRuleDialog>/rule/ruleName}" placeholder="Enter a descriptive name for this rule" />
                                    
                                    <Label text="Description" />
                                    <TextArea value="{processingRuleDialog>/rule/description}" rows="3" />
                                    
                                    <Label text="File Type" required="true" />
                                    <Select selectedKey="{processingRuleDialog>/rule/fileType}">
                                        <core:Item key="EXCEL" text="Excel" />
                                        <core:Item key="CSV" text="CSV" />
                                        <core:Item key="PDF" text="PDF" />
                                        <core:Item key="XML" text="XML" />
                                    </Select>
                                    
                                    <Label text="Rule Type" required="true" />
                                    <Input value="{processingRuleDialog>/rule/ruleType}" />
                                    
                                    <Label text="Active" />
                                    <Switch state="{processingRuleDialog>/rule/active}" customTextOn="Yes" customTextOff="No" />
                                </f:content>
                            </f:SimpleForm>
                        </VBox>
                    </IconTabFilter>
                    
                    <IconTabFilter key="conditions" text="Conditions" count="{= ${processingRuleDialog>/rule/conditions} ? ${processingRuleDialog>/rule/conditions}.length : 0}" icon="sap-icon://filter">
                        <VBox class="sapUiSmallMargin">
                            <Toolbar>
                                <Title text="Conditions" level="H4" />
                                <ToolbarSpacer />
                                <Button text="Add Condition" icon="sap-icon://add" type="Emphasized" press="onAddRuleCondition" />
                            </Toolbar>
                            
                            <Table
                                id="ruleConditionsTable"
                                items="{processingRuleDialog>/rule/conditions}"
                                class="sapUiSizeCompact"
                                mode="None">
                                <columns>
                                    <Column width="30%"><Text text="Attribute" /></Column>
                                    <Column width="25%"><Text text="Operator" /></Column>
                                    <Column width="35%"><Text text="Value" /></Column>
                                    <Column width="5%" hAlign="Center"><Text text="" /></Column>
                                    <Column width="5%" hAlign="Center"><Text text="" /></Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Input value="{processingRuleDialog>attribute}" placeholder="e.g., Invoice Number" />
                                            <Select selectedKey="{processingRuleDialog>operator}">
                                                <core:Item key="exists" text="Exists" />
                                                <core:Item key="equals" text="Equals" />
                                                <core:Item key="contains" text="Contains" />
                                                <core:Item key="startsWith" text="Starts with" />
                                                <core:Item key="endsWith" text="Ends with" />
                                                <core:Item key="greaterThan" text="Greater than" />
                                                <core:Item key="lessThan" text="Less than" />
                                                <core:Item key="matches" text="Matches" />
                                                <core:Item key="isEmpty" text="Is Empty" />
                                            </Select>
                                            <Input value="{processingRuleDialog>value}" placeholder="e.g., Source Value" />
                                            <Button icon="sap-icon://edit" type="Transparent" press="onEditRuleCondition" tooltip="Edit" />
                                            <Button icon="sap-icon://delete" type="Reject" press="onDeleteRuleCondition" tooltip="Delete" />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </VBox>
                    </IconTabFilter>
                    
                    <IconTabFilter key="apiMappings" text="API Mappings" count="{= ${processingRuleDialog>/rule/apiMappings} ? ${processingRuleDialog>/rule/apiMappings}.length : 0}" icon="sap-icon://source-code">
                        <VBox class="sapUiSmallMargin">
                            <Toolbar>
                                <Title text="API Mappings" level="H5" />
                                <ToolbarSpacer />
                                <Button text="Add Mapping" icon="sap-icon://add" type="Emphasized" press="onAddApiMapping" />
                            </Toolbar>
                            
                            <Table
                                id="apiMappingsTable"
                                items="{processingRuleDialog>/rule/apiMappings}"
                                class="sapUiSizeCompact">
                                <columns>
                                    <Column width="15%"><Text text="Source Type" /></Column>
                                    <Column width="25%"><Text text="Destination" /></Column>
                                    <Column width="10%"><Text text="Method" /></Column>
                                    <Column width="40%"><Text text="Service URL" /></Column>
                                    <Column width="5%" hAlign="Center"><Text text="" /></Column>
                                    <Column width="5%" hAlign="Center"><Text text="" /></Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Select selectedKey="{processingRuleDialog>sourceType}">
                                                <core:Item key="OData V2" text="OData V2" />
                                                <core:Item key="OData V4" text="OData V4" />
                                                <core:Item key="REST" text="REST API" />
                                                <core:Item key="SOAP" text="SOAP" />
                                            </Select>
                                            <Input value="{processingRuleDialog>destination}" placeholder="e.g., S4HANA_SYSTEM_DESTINATION" />
                                            <Select selectedKey="{processingRuleDialog>httpMethod}">
                                                <core:Item key="GET" text="GET" />
                                                <core:Item key="POST" text="POST" />
                                                <core:Item key="PUT" text="PUT" />
                                                <core:Item key="DELETE" text="DELETE" />
                                            </Select>
                                            <Input value="{processingRuleDialog>apiReference}" placeholder="Service URL" />
                                            <Button icon="sap-icon://edit" type="Transparent" press="onEditApiMapping" tooltip="Edit" />
                                            <Button icon="sap-icon://delete" type="Reject" press="onDeleteApiMapping" tooltip="Delete" />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </VBox>
                    </IconTabFilter>
                    
                    <IconTabFilter key="fieldMappings" text="Field Mapping" count="{= ${processingRuleDialog>/rule/fieldMappings} ? ${processingRuleDialog>/rule/fieldMappings}.length : 0}" icon="sap-icon://map">
                        <VBox class="sapUiSmallMargin">
                            <Toolbar>
                                <Title text="Field Mappings" level="H5" />
                                <ToolbarSpacer />
                                <Button text="Add Mapping" icon="sap-icon://add" type="Emphasized" press="onAddFieldMapping" />
                            </Toolbar>
                            
                            <Table
                                id="fieldMappingsTable"
                                items="{processingRuleDialog>/rule/fieldMappings}"
                                class="sapUiSizeCompact">
                                <columns>
                                    <Column width="30%"><Text text="Source Field" /></Column>
                                    <Column width="30%"><Text text="Target Field (Output)" /></Column>
                                    <Column width="30%"><Text text="API Field" /></Column>
                                    <Column width="5%" hAlign="Center"><Text text="" /></Column>
                                    <Column width="5%" hAlign="Center"><Text text="" /></Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Input value="{processingRuleDialog>sourceField}" placeholder="e.g., Invoice Number" />
                                            <Input value="{processingRuleDialog>targetField}" placeholder="e.g., AccountingDocument" />
                                            <Input value="{processingRuleDialog>apiField}" placeholder="e.g., PaymentReference" />
                                            <Button icon="sap-icon://edit" type="Transparent" press="onEditFieldMapping" tooltip="Edit" />
                                            <Button icon="sap-icon://delete" type="Reject" press="onDeleteFieldMapping" tooltip="Delete" />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </VBox>
                    </IconTabFilter>
                </items>
            </IconTabBar>
        </content>
        
        <beginButton>
            <Button text="Save" type="Emphasized" press="onSaveProcessingRule" />
        </beginButton>
        <endButton>
            <Button text="Cancel" press="onCloseProcessingRuleDialog" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
